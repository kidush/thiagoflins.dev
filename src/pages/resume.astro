---
import Base from '../layouts/Base.astro';

const experience = [
  {
    title: 'Sr. Software Engineer',
    company: 'TrustLayer',
    period: 'Oct 2025 – Present',
    bullets: [
      'Architecting the integration layer between the core TypeScript application and external third-party insurance and compliance providers.',
      'Building and maintaining a Ruby on Rails middleware service for seamless cross-system communication, using Temporal for workflow orchestration.',
      'Managing data integrity across dual-database environments (MongoDB + PostgreSQL) in high-throughput compliance workflows.',
    ],
    tags: ['Ruby on Rails', 'TypeScript', 'React', 'Temporal', 'Sidekiq', 'MongoDB', 'PostgreSQL'],
  },
  {
    title: 'Sr. Software Engineer',
    company: 'PayPal (Contractor)',
    period: 'Jan 2025 – Oct 2025',
    bullets: [
      'Core Disputes team: owned end-to-end management and resolution of chargeback cases across the PayPal/Braintree platform.',
      'Built Datadog observability dashboards to track chargeback volumes, dispute states, and platform health metrics.',
    ],
    tags: ['Ruby on Rails', 'Datadog', 'Braintree'],
  },
  {
    title: 'Sr. Software Engineer',
    company: 'Equinix',
    period: 'Apr 2024 – Jan 2025',
    bullets: [
      'Maintained Core Services Infrastructure APIs serving internal and external customers under demanding SLAs.',
      'Improved API throughput by 10% via Ruby JIT compilation and Rails version migration.',
      'Planned and executed a zero-downtime Rails API version migration across a high-traffic service.',
    ],
    tags: ['Go', 'Ruby on Rails', 'Terraform', 'GraphQL'],
  },
  {
    title: 'Sr. Ruby Engineer',
    company: 'Turing.com (Equinix)',
    period: 'Nov 2021 – Apr 2024',
    bullets: [
      'Embedded in the Equinix bare metal cloud team, ensuring stability and peak performance of the core infrastructure API.',
      'Collaborated with globally distributed teams to maintain cloud-grade reliability for external customers.',
    ],
    tags: ['Go', 'Ruby on Rails', 'Terraform', 'GraphQL'],
  },
  {
    title: 'Ruby Developer',
    company: 'Applaudo Studios',
    period: 'Jun 2021 – Nov 2021',
    bullets: [
      'Built Strainer, an internal platform for evaluating developer skills during hiring.',
      'Developed the SXSW Chat app with real-time messaging via GetStream.',
    ],
    tags: ['Ruby on Rails', 'Sidekiq', 'Redis', 'PostgreSQL', 'ReactJS', 'Docker'],
  },
  {
    title: 'Software Developer',
    company: 'Safety System Technology',
    period: 'Apr 2015 – Jun 2021',
    bullets: [
      'Full-stack contributor to Safety Care, a telehealth application on AWS — from architecture through production.',
      'Built SafetyID, a facial recognition system for document verification using Python + Ruby, deployed on Rancher/AWS.',
    ],
    tags: ['Ruby on Rails', 'Python', 'PostgreSQL', 'AWS', 'Docker', 'Rancher'],
  },
  {
    title: 'Full-Stack Developer',
    company: 'Spocket Co. (Part-time)',
    period: 'Apr 2018 – Jan 2020',
    bullets: [
      'Owned WooCommerce integration development and maintenance for the Spocket platform.',
    ],
    tags: ['Ruby on Rails', 'Redis', 'Sidekiq', 'PostgreSQL', 'PHP', 'Vue.js'],
  },
];

const skills = [
  { label: 'Backend',           items: ['Ruby', 'Rails', 'Go', 'Python', 'TypeScript'] },
  { label: 'Frontend',          items: ['JavaScript', 'React', 'Vue.js', 'HTML5', 'CSS3'] },
  { label: 'APIs & Architecture', items: ['REST', 'GraphQL', 'Microservices', 'Event-driven'] },
  { label: 'Databases',         items: ['PostgreSQL', 'MongoDB', 'Redis'] },
  { label: 'DevOps & Cloud',    items: ['Kubernetes', 'Docker', 'Terraform', 'AWS', 'Heroku', 'ArgoCD', 'GitHub Actions', 'Datadog'] },
  { label: 'Practices',         items: ['TDD', 'CI/CD', 'RSpec', 'Agile', 'System Design'] },
];

const education = [
  { degree: 'Postgraduate Specialization in Software Architecture', school: 'FIAP, São Paulo', year: '2024' },
  { degree: 'Technology Degree in Information Systems', school: 'CESMAC, Maceió', year: '2022' },
];

const courses = [
  { name: 'Functional Programming with Erlang', school: 'University of Kent', year: '2017' },
  { name: 'Modern Software Engineering (48h)', school: 'UFMG / ICEx', year: '2022' },
];
---

<Base title="Resume">
  <div class="page">

    <!-- HEADER -->
    <header>
      <div>
        <p class="hero-label">Senior Software Engineer</p>
        <h1>Thiago <em>Lins</em></h1>
        <p class="tagline">Ruby on Rails · Backend &amp; Cloud Infrastructure · 10+ years building high-availability systems at scale</p>
        <div class="open-badge">
          <span class="pulse-dot" />
          Open to relocation · Visa sponsorship
        </div>
      </div>
      <div class="contacts">
        <span>Maceió, Brazil</span>
        <a href="mailto:thiago.evandson@gmail.com">thiago.evandson@gmail.com</a>
        <a href="https://github.com/kidush" target="_blank" rel="noopener">github.com/kidush</a>
        <a href="https://linkedin.com/in/thiagoevan" target="_blank" rel="noopener" class="linkedin-btn">
          <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
    </header>

    <!-- MAIN GRID -->
    <div class="main">

      <!-- LEFT -->
      <div>
        <section>
          <p class="section-label">Profile</p>
          <p class="summary-text">Ruby on Rails engineer with 10+ years of experience building high-availability APIs and cloud infrastructure at scale. Proven track record at PayPal, Equinix, and TrustLayer — delivering measurable performance gains, leading complex API migrations, and integrating third-party systems in high-demand environments. Experienced with DevOps practices, CI/CD pipelines, and distributed systems.</p>
        </section>

        <section>
          <p class="section-label">Experience</p>
          {experience.map((job, i) => (
            <div class="job" style={`animation-delay: ${i * 0.05}s`}>
              <div class="job-header">
                <span class="job-title">{job.title}</span>
                <span class="job-period">{job.period}</span>
              </div>
              <div class="job-company">{job.company}</div>
              <ul>
                {job.bullets.map(b => <li>{b}</li>)}
              </ul>
              <div class="tech-tags">
                {job.tags.map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
          ))}
        </section>
      </div>

      <!-- SIDEBAR -->
      <aside>
        <div class="sidebar-section">
          <p class="section-label">Skills</p>
          {skills.map(group => (
            <div class="skill-group">
              <div class="skill-group-label">{group.label}</div>
              <div class="skill-list">
                {group.items.map(i => <span class="tag">{i}</span>)}
              </div>
            </div>
          ))}
        </div>

        <div class="sidebar-section">
          <p class="section-label">Education</p>
          {education.map(e => (
            <div class="edu-item">
              <div class="edu-degree">{e.degree}</div>
              <div class="edu-school">{e.school} · {e.year}</div>
            </div>
          ))}
        </div>

        <div class="sidebar-section">
          <p class="section-label">Courses</p>
          {courses.map(c => (
            <div class="edu-item">
              <div class="edu-degree">{c.name}</div>
              <div class="edu-school">{c.school} · {c.year}</div>
            </div>
          ))}
        </div>

        <div class="sidebar-section">
          <p class="section-label">Languages</p>
          <div class="lang-row"><span>English</span><span class="lang-level">Proficient</span></div>
          <div class="lang-row"><span>Portuguese</span><span class="lang-level">Native</span></div>
        </div>
      </aside>

    </div>
  </div>
</Base>

<style>
  header {
    padding: 80px 0 60px;
    border-bottom: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 32px;
    align-items: end;
    animation: fadeUp .7s ease both;
  }

  .hero-label {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(2.4rem, 6vw, 4rem);
    line-height: 1.05;
    letter-spacing: -.02em;
    color: #fff;
    margin-bottom: 12px;
  }
  h1 em { font-style: italic; color: var(--accent); }

  .tagline { color: var(--muted); font-size: 14px; max-width: 420px; }

  .open-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--accent2);
    color: var(--accent2);
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: .15em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 2px;
    margin-top: 16px;
  }
  .pulse-dot {
    width: 6px; height: 6px;
    background: var(--accent2);
    border-radius: 50%;
    animation: pulse 2s ease infinite;
    flex-shrink: 0;
  }

  .contacts {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-end;
  }
  .contacts a, .contacts span {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: .05em;
    transition: color .2s;
  }
  .contacts a:hover { color: var(--accent); }

  .linkedin-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: #0d0d0d !important;
    padding: 8px 16px;
    border-radius: 2px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background .2s, transform .15s;
    margin-top: 4px;
  }
  .linkedin-btn:hover { background: #d8ff5a; transform: translateY(-1px); }

  .main {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 0 48px;
    padding: 60px 0;
  }

  section { margin-bottom: 56px; }

  .summary-text { font-size: 15px; color: #b0b0b0; line-height: 1.8; }

  .job {
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
    animation: fadeUp .5s ease both;
  }
  .job:first-of-type { border-top: 1px solid var(--border); }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 4px;
  }
  .job-title { font-family: 'DM Serif Display', serif; font-size: 1.1rem; font-weight: 400; color: #fff; }
  .job-period { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted); letter-spacing: .08em; white-space: nowrap; }
  .job-company { font-size: 12px; color: var(--accent); font-family: 'DM Mono', monospace; letter-spacing: .05em; margin-bottom: 12px; }

  .job ul { list-style: none; padding: 0; margin-bottom: 12px; }
  .job ul li { font-size: 13.5px; color: #9a9a9a; padding: 3px 0 3px 16px; position: relative; line-height: 1.6; }
  .job ul li::before { content: '—'; position: absolute; left: 0; color: var(--border); }

  /* SIDEBAR */
  .sidebar-section { margin-bottom: 40px; }
  .skill-group { margin-bottom: 20px; }
  .skill-group-label { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--accent); letter-spacing: .12em; text-transform: uppercase; margin-bottom: 8px; }
  .skill-list { display: flex; flex-wrap: wrap; gap: 5px; }

  .edu-item { margin-bottom: 16px; }
  .edu-degree { font-size: 13px; color: var(--text); line-height: 1.4; }
  .edu-school { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted); margin-top: 2px; }

  .lang-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid var(--border); font-size: 13px; }
  .lang-level { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted); }

  @media (max-width: 680px) {
    header { grid-template-columns: 1fr; }
    .contacts { align-items: flex-start; }
    .main { grid-template-columns: 1fr; }
  }
</style>
