---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base title="Home">
  <div class="page">

    <!-- HERO -->
    <section class="hero">
      <p class="hero-label">Senior Software Engineer</p>
      <h1>Thiago <em>Lins</em></h1>
      <p class="hero-sub">Ruby on Rails · Backend &amp; Cloud Infrastructure · 10+ years building high-availability systems at scale</p>
      <div class="open-badge">
        <span class="pulse-dot" />
        Open to relocation · Visa sponsorship
      </div>
      <div class="hero-links">
        <a href="/resume" class="cta-btn">View Resume</a>
        <a href="https://github.com/kidush" target="_blank" rel="noopener" class="ghost-btn">GitHub ↗</a>
        <a href="https://linkedin.com/in/thiagoevan" target="_blank" rel="noopener" class="ghost-btn linkedin">
          <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="about">
      <p class="section-label">About</p>
      <p class="about-text">
        I'm a backend engineer based in Maceió, Brazil, currently building compliance infrastructure at TrustLayer.
        I specialize in Ruby on Rails, distributed systems, and third-party API integrations — with past experience
        at PayPal, Equinix, and early-stage product companies. I'm open to senior roles in the US, Canada, and Europe.
      </p>
    </section>

    <!-- STACK HIGHLIGHTS -->
    <section class="stack">
      <p class="section-label">Stack</p>
      <div class="stack-grid">
        {[
          { label: 'Backend',   items: ['Ruby on Rails', 'Go', 'Python', 'TypeScript'] },
          { label: 'Databases', items: ['PostgreSQL', 'MongoDB', 'Redis'] },
          { label: 'DevOps',    items: ['Kubernetes', 'Docker', 'Terraform', 'AWS'] },
          { label: 'APIs',      items: ['REST', 'GraphQL', 'Temporal', 'Sidekiq'] },
        ].map(group => (
          <div class="stack-group">
            <span class="stack-group-label">{group.label}</span>
            <div class="tech-tags">
              {group.items.map(i => <span class="tag">{i}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- LATEST POSTS -->
    {posts.length > 0 && (
      <section class="latest-posts">
        <p class="section-label">Latest Posts</p>
        <ul class="post-list">
          {posts.map(post => (
            <li class="post-item">
              <a href={`/blog/${post.slug}`} class="post-link">
                <span class="post-title">{post.data.title}</span>
                <span class="post-date">{formatDate(post.data.date)}</span>
              </a>
              {post.data.description && <p class="post-desc">{post.data.description}</p>}
            </li>
          ))}
        </ul>
        <a href="/blog" class="ghost-btn" style="margin-top: 24px; display: inline-block;">All posts →</a>
      </section>
    )}

  </div>
</Base>

<style>
  /* HERO */
  .hero {
    padding: 80px 0 60px;
    border-bottom: 1px solid var(--border);
    animation: fadeUp .7s ease both;
  }

  .hero-label {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(2.4rem, 6vw, 4rem);
    line-height: 1.05;
    letter-spacing: -.02em;
    color: #fff;
    margin-bottom: 12px;
  }

  h1 em { font-style: italic; color: var(--accent); }

  .hero-sub {
    color: var(--muted);
    font-size: 14px;
    max-width: 480px;
    margin-bottom: 20px;
  }

  .open-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--accent2);
    color: var(--accent2);
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: .15em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 2px;
    margin-bottom: 28px;
  }

  .pulse-dot {
    width: 6px; height: 6px;
    background: var(--accent2);
    border-radius: 50%;
    animation: pulse 2s ease infinite;
    flex-shrink: 0;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .cta-btn {
    background: var(--accent);
    color: #0d0d0d;
    padding: 9px 20px;
    border-radius: 2px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background .2s, transform .15s;
  }
  .cta-btn:hover { background: #d8ff5a; transform: translateY(-1px); }

  .ghost-btn {
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 9px 16px;
    border-radius: 2px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: .08em;
    text-decoration: none;
    transition: border-color .2s, color .2s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .ghost-btn:hover { border-color: var(--accent); color: var(--accent); }
  .ghost-btn.linkedin:hover { border-color: #0a66c2; color: #0a66c2; }

  /* ABOUT */
  .about { padding: 52px 0 0; }
  .about-text { color: #b0b0b0; font-size: 15px; line-height: 1.8; max-width: 680px; }

  /* STACK */
  .stack { padding: 52px 0 0; }
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 28px;
  }
  .stack-group-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--accent);
    letter-spacing: .12em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 10px;
  }

  /* LATEST POSTS */
  .latest-posts { padding: 52px 0 0; }
  .post-list { list-style: none; }
  .post-item {
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }
  .post-item:first-child { border-top: 1px solid var(--border); }
  .post-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    text-decoration: none;
    flex-wrap: wrap;
  }
  .post-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.05rem;
    color: #fff;
    transition: color .2s;
  }
  .post-link:hover .post-title { color: var(--accent); }
  .post-date {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    white-space: nowrap;
  }
  .post-desc {
    font-size: 13px;
    color: var(--muted);
    margin-top: 4px;
  }

  @media (max-width: 520px) {
    .stack-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
